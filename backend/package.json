    "@fastify/swagger-ui": "^5.2.3",
    "bullmq": "^5.53.0",
    "drizzle-orm": "^0.43.1",
    "fastify": "^5.3.2",
    "ioredis": "^5.6.1",
    "pg": "^8.16.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.19",
